# Editor configuration — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_size = 2

[*.{json,json5,jsonc}]
indent_size = 2

[*.{md,mdown,mkd,mkdn,markdown}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf
indent_style = tab

[*.cmd]
end_of_line = crlf

[*.ps1]
indent_size = 4
